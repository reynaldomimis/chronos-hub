<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- GLOW OUTER -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#420F83EC"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <!-- MAIN GRADIENT BORDER -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">

        <shape android:shape="rectangle">
            <gradient
                android:startColor="#560E83"
                android:endColor="#06A4F9"
                android:angle="180" />
            <corners android:radius="14dp" />
        </shape>

    </item>

    <!-- INNER GLASS -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">

        <shape android:shape="rectangle">
            <solid android:color="#0D0C29"/>
            <corners android:radius="12dp" />
        </shape>

    </item>

</layer-list>