<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:paddingTop="10dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatar"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:scaleType="centerCrop"
        android:src="@drawable/img"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundedProfile"
        app:strokeColor="@color/color_top"
        app:strokeWidth="4dp" />

    <TextView
        android:id="@+id/name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/default_username"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/points_redeem_container"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintTop_toTopOf="@id/avatar"
        app:layout_constraintBottom_toTopOf="@+id/id_container"
        app:layout_constraintVertical_chainStyle="packed" />

    <LinearLayout
        android:id="@+id/id_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="@id/name"
        app:layout_constraintEnd_toStartOf="@id/points_redeem_container"
        app:layout_constraintTop_toBottomOf="@+id/name"
        app:layout_constraintBottom_toBottomOf="@id/avatar"
        tools:ignore="UseCompoundDrawables">

        <TextView
            android:id="@+id/referer_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_userid"
            android:textColor="@color/color_secondary"
            android:textSize="12sp" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_menu_save"
            android:importantForAccessibility="no"
            app:tint="@color/white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/points_redeem_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/color_top"
        app:contentPadding="0dp"
        app:cardElevation="1dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/stroke"
        app:shapeAppearanceOverlay="@style/RedeemCard"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="2dp">

            <ImageView
                android:id="@+id/coin_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_coin"
                android:importantForAccessibility="no"
              />

            <TextView
                android:id="@+id/points_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp"
                android:text="@string/default_points"
                android:textColor="@color/color_secondary"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_redeem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_redeem_btn"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/color_secondary"
                app:shapeAppearanceOverlay="@style/RedeemCard"
                app:elevation="0dp"
                app:pressedTranslationZ="0dp"
                app:cornerRadius="5dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>